{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "igltf-editor",
  "version": "0.1.0",
  "identifier": "com.interactivegltf.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "interactive glTF Editor",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "interactive glTF",
    "shortDescription": "Authoring environment for interactive glTF (igltf-editor)",
    "copyright": "Copyright (c) igltf-engine contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/igltf-backend/": "igltf-backend/"
    }
  }
}
