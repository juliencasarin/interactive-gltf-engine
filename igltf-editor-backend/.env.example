# Copy to .env and adjust. Loaded automatically when the app starts.

# App-state directory (default ./data beside pyproject.toml): holds projects.json (+ optional legacy slug subfolders).
# STORAGE_ROOT=C:/path/to/app-state

# Alias for STORAGE_ROOT — first non-empty wins (see app/storage.py).
# IGLTF_APP_DATA_DIR=C:/path/to/app-state

# Workspace folders listed in projects.json live at arbitrary absolute diskPath locations.

# Base URL the browser uses to reach this API (used in asset upload response URLs).
# Same value is templated into each workspace ./mcp.json (MCP endpoint = PUBLIC_BASE_URL + /mcp).
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional alternate authoring kit folder (absolute path); default is authoring_kit bundled with backend.
# IGLTF_AUTHORING_KIT=C:/path/to/custom/authoring_kit

# MCP read ceiling for igltf_read_framework_file (bytes). Default if unset: 524288.
# IGLTF_AUTHORING_READ_MAX_BYTES=524288

# Vite / Tauri WebView origins (comma-separated, optional spaces trimmed)
# Default in app/main.py also includes https://tauri.localhost and DevTools port 1420 for Tauri shells.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://tauri.localhost,http://tauri.localhost

# Max upload size in MB (multipart asset upload)
# MAX_UPLOAD_MB=200
