# Copy to .env and adjust. Loaded automatically when the app starts.

# Optional: absolute path for project + asset storage (default: ./data next to pyproject.toml)
# STORAGE_ROOT=C:/path/to/storage

# Base URL the browser uses to reach this API (used in asset upload response URLs)
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Vite dev server origins (comma-separated, no spaces after commas)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Max upload size in MB (multipart asset upload)
# MAX_UPLOAD_MB=200
